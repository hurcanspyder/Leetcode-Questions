   "source": [
    "def solve(node):\n",
    "    if node==None:\n",
    "        return 0\n",
    "    \n",
    "    LH=solve(node.left)\n",
    "    if LH==-1:\n",
    "        return -1\n",
    "    \n",
    "    RH=solve(node.right)\n",
    "    if RH==-1:\n",
    "        return -1\n",
    "    if abs(LH-RH)>1:\n",
    "        return -1\n",
    "    else:\n",
    "        return 1+max(LH,RH) \n",
    "    \n"
   ]
