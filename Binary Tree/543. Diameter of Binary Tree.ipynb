   "source": [
    "def solve(node):\n",
    "    if node==None:\n",
    "        return 0\n",
    "    path=0\n",
    "    height=0\n",
    "    LH=solve(node)\n",
    "    RH=solve(node)\n",
    "    path=max(path,RH+LH)\n",
    "    return 1+max(LH,RH)\n",
    "\n",
    "    \n"
   ]
  }
