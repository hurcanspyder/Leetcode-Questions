   "source": [
    "def transpose(list1):\n",
    "    rows=len(list1)\n",
    "    cols=len(list1[0])\n",
    "    result=[[0]*rows for _ in range(cols)]\n",
    "    for i in range(0,rows):\n",
    "        for j in range(0,cols):\n",
    "            result[j][i]=list1[i][j]\n",
    "    print(result)"
   ]
  },
