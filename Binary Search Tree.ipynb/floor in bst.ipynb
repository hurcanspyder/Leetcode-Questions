   "source": [
    "def solve(root,inp):\n",
    "    ans=-1\n",
    "    temp=root\n",
    "    while temp is not None:\n",
    "        if temp.val<=inp:\n",
    "            ans=temp.val\n",
    "            temp=temp.right\n",
    "        else:\n",
    "            temp=temp.left\n",
    "    return ans\n",
    "\n"
   ]
  },
