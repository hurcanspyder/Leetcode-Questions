   "source": [
    "def seil(root,inp):\n",
    "    ceil=-1\n",
    "    while root is not None:\n",
    "        if root.val==inp:\n",
    "            return root.val\n",
    "        elif root.key<inp:\n",
    "            root=root.right\n",
    "        else:\n",
    "            ceil=root.key\n",
    "            root=root.left\n",
    "    return ceil"
   ]
  },
