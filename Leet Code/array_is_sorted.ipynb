   "source": [
    "def array_is_sorted(list1):\n",
    "    for i in range(0,len(list1)-1):\n",
    "        if list1[i]>list1[i+1]:\n",
    "            return False\n",
    "    return True"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "c7df481c",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "True"
      ]
     },
     "execution_count": 4,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "array_is_sorted([1,2,3,4,5,6,7,8,9])"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a6ed7e2b",
   "metadata": {},
   "source": [
    "**Here the time complexity is O(n) and space complexity is O(1)**"
