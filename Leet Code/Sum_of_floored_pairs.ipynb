   "source": [
    "def sum(nums):\n",
    "    sum=0\n",
    "    for i in range(0,len(nums)):\n",
    "        for j in range(0,len(nums)):\n",
    "            sum=sum+nums[i]//nums[j]\n",
    "    return sum"
   ]
