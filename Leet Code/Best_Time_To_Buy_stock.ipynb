   "source": [
    "def best_time(list1):\n",
    "    min=100**30\n",
    "    differnce=-10**30\n",
    "    for i in range(0,len(list1)):\n",
    "        if min>list1[i]:\n",
    "            min=list1[i]\n",
    "        if list1[i]-min>differnce:\n",
    "            differnce=list1[i]-min\n",
    "\n",
    "    return differnce\n",
    "\n"
   ]
  },
