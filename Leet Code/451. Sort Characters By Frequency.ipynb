   "source": [
    "from collections import Counter\n",
    "\n",
    "class Solution(object):\n",
    "    def frequencySort(self, s):\n",
    "        count = Counter(s)\n",
    "        sorted_items = sorted(count.items(), key=lambda x: x[1], reverse=True)\n",
    "        return ''.join([ch * freq for ch, freq in sorted_items])\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "        "
   ]
  }
