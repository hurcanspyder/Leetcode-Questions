   "source": [
    "def solve(n):\n",
    "    if n == 1:\n",
    "        return True\n",
    "    if n <= 0 or n % 4 != 0:\n",
    "        return False\n",
    "    return solve(n // 4)\n",
    "\n",
    "    "
   ]
