   "source": [
    "def solve(nums):\n",
    "    max_index=0\n",
    "    for i in range(0,len(nums)):\n",
    "        if i>max_index:\n",
    "            return False\n",
    "        max_index=max(max_index,i+nums[i])\n",
    "    return True"
   ]
