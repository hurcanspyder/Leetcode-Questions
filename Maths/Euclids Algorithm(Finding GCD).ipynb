   "source": [
    "**Prerequisite->a should always be greater than b**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "80445b1c",
   "metadata": {},
   "outputs": [],
   "source": [
    "def euclidsalgo(a,b):\n",
    "\n",
    "    if b==0:\n",
    "        return a\n",
    "    else:\n",
    "        return euclidsalgo(b,a%b)\n"
   ]
  },
