    "class Solution(object):\n",
    "    def smallestRangeI(self, nums, k):\n",
    "        \"\"\"\n",
    "        :type nums: List[int]\n",
    "        :type k: int\n",
    "        :rtype: int\n",
    "        \"\"\"\n",
    "        maxi=max(nums)\n",
    "        mini=min(nums)\n",
    "        return max(0,maxi-mini-2*k)"
   ]
  }
