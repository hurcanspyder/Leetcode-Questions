    "class Solution(object):\n",
    "    def singleNumber(self, nums):\n",
    "        \"\"\"\n",
    "        :type nums: List[int]\n",
    "        :rtype: int\n",
    "        \"\"\"\n",
    "        xor=0\n",
    "        for i in range(0,len(nums)):\n",
    "            xor=xor^nums[i]\n",
    "        return xor"
   ]
