   "source": [
    "def solve(n,index,result,result1):\n",
    "    if index>=n:\n",
    "        result1.append(result.copy())\n",
    "        return\n",
    "        \n",
    "    result[index]=1\n",
    "    solve(n,index+1,result,result1)\n",
    "    result[index]=0\n",
    "    solve(n,index+1,result,result1)\n",
    "    return result1\n",
    "\n",
    "\n"
   ]
  },
